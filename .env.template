# Local development template only.
# Copy this file to .env.local and fill with non-production values.
# Never commit real secrets.

APP_ENV=local
API_BASE_URL=http://localhost:8080

# Firebase public client config (public)
FIREBASE_API_KEY=public-placeholder
FIREBASE_AUTH_DOMAIN=public-placeholder
FIREBASE_PROJECT_ID=public-placeholder

# Backend runtime secrets (local dev placeholders only)
BACKEND_JWT_SIGNING_KEY=change-me-local-only
BACKEND_FIREBASE_PROJECT_ID=your-firebase-project-id
BACKEND_FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=base64-encoded-service-account-json
BACKEND_DB_DSN=postgres://user:pass@localhost:5432/gdg_events?sslmode=disable
BACKEND_REDIS_ADDR=localhost:6379
BACKEND_REDIS_PASSWORD=change-me-local-only
